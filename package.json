{
  "name": "van-cli",
  "version": "2.0.0",
  "description": "TypeScript CLI wrapper for the NGP VAN API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "van": "./bin/cli.js",
    "van-cli": "./bin/cli.js",
    "ea": "./bin/cli.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "dev": "node dist/cli.js",
    "test": "npm run build && jest --runInBand",
    "test:coverage": "npm run build && jest --coverage --runInBand",
    "prepack": "npm run clean && tsc -p tsconfig.build.json"
  },
  "keywords": [
    "ngp",
    "van",
    "api",
    "cli",
    "political",
    "crm",
    "typescript"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "chalk": "^4.1.2",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
